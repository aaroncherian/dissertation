@article{morrisGaitRatherCognition2017,
  title = {Gait {{Rather Than Cognition Predicts Decline}} in {{Specific Cognitive Domains}} in {{Early Parkinson}}’s {{Disease}}},
  author = {Morris, Rosie and Lord, Sue and Lawson, Rachael A and Coleman, Shirley and Galna, Brook and Duncan, Gordon W and Khoo, Tien K and Yarnall, Alison J and Burn, David J and Rochester, Lynn},
  date = {2017-11},
  journaltitle = {The Journals of Gerontology Series A: Biological Sciences and Medical Sciences},
  shortjournal = {J Gerontol A Biol Sci Med Sci},
  volume = {72},
  number = {12},
  eprint = {28472409},
  eprinttype = {pubmed},
  pages = {1656--1662},
  issn = {1079-5006},
  doi = {10.1093/gerona/glx071},
  url = {https://pmc.ncbi.nlm.nih.gov/articles/PMC5861960/},
  urldate = {2026-03-07},
  abstract = {Background Dementia is significant in Parkinson’s disease (PD) with personal and socioeconomic impact. Early identification of risk is of upmost importance to optimize management. Gait precedes and predicts cognitive decline and dementia in older adults. We aimed to evaluate gait characteristics as predictors of cognitive decline in newly diagnosed PD. Methods One hundred and nineteen participants recruited at diagnosis were assessed at baseline, 18 and 36 months. Baseline gait was characterized by variables that mapped to five domains: pace, rhythm, variability, asymmetry, and postural control. Cognitive assessment included attention, fluctuating attention, executive function, visual memory, and visuospatial function. Mixed-effects models tested independent gait predictors of cognitive decline. Results Gait characteristics of pace, variability, and postural control predicted decline in fluctuating attention and visual memory, whereas baseline neuropsychological assessment performance did not predict decline. Conclusions This provides novel evidence for gait as a clinical biomarker for PD cognitive decline in early disease.},
  pmcid = {PMC5861960},
  file = {C:\Users\aaron\Zotero\storage\IZU6I38Y\Morris et al. - 2017 - Gait Rather Than Cognition Predicts Decline in Specific Cognitive Domains in Early Parkinson’s Disea.pdf}
}

