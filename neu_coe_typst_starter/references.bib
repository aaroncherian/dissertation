@online{dariciLowCostMarkerlessMotion2025a,
  title = {A {{Low-Cost Markerless}} Motion Capture System to Automate {{Functional Gait Assessment}}: {{Feasibility Study}}},
  shorttitle = {A {{Low-Cost Markerless}} Motion Capture System to Automate {{Functional Gait Assessment}}},
