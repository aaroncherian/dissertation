  shorttitle = {3-{{D}} Model-Based Tracking of Humans in Action},
  booktitle = {Proceedings {{CVPR IEEE Computer Society Conference}} on {{Computer Vision}} and {{Pattern Recognition}}},
  author = {Gavrila, D.M. and Davis, L.S.},
